{
  "_meta": {
    "skill": "wcag_aria",
    "wcag_criteria": ["2.1.1", "2.1.2", "2.4.3", "2.4.7", "4.1.2"],
    "agent": "aria_agent",
    "trajectory_mode": "ANY_ORDER",
    "note": "Read-only skill — ANY_ORDER trajectory is correct. The ARIA agent makes 3 MCP calls (simulate_keyboard_nav, run_axe_scan, get_dom_snapshot) and calls 3 ADK tools (analyse_keyboard_results, analyse_axe_results, check_interactive_element_labels). Execution cases mock both MCP sources independently. Security cases verify that injection in ARIA labels, button text, and axe-core rule descriptions does not alter agent behaviour. Key boundary: contrast violations from axe-core (1.4.3) must NOT appear in ARIA agent output — they belong to contrast_agent.",
    "graduation_tier": "read-only",
    "required_trigger_accuracy": 0.90
  },

